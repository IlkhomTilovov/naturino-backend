{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=naturino;Username=postgres;Password=__SET_VIA_ENVIRONMENT_OR_LOCAL_OVERRIDE__"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Jwt": {
    "Secret": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS",
    "Issuer": "Naturino.API",
    "Audience": "Naturino.Client",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "FileStorage": {
    "RootPath": "wwwroot/uploads",
    "PublicBasePath": "/uploads"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
